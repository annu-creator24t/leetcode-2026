SELECT 
    ROUND(
        COUNT(*) / (SELECT COUNT(DISTINCT player_id) FROM Activity), 
        2
    ) AS fraction
FROM (
    SELECT player_id, MIN(event_date) AS first_date
    FROM Activity
    GROUP BY player_id
) t
WHERE EXISTS (
    SELECT 1
    FROM Activity a2
    WHERE a2.player_id = t.player_id
      AND a2.event_date = DATE_ADD(t.first_date, INTERVAL 1 DAY)
);
